# ---- JawnRemote ----

# Server (Python)
server/pin.txt
server/apps.json
server/__pycache__/
server/build/
server/dist/
server/*.spec
!server/JawnRemoteServer.spec
*.pyc

# ---- Flutter / Dart (app/) ----
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/build/
app/.gradle/
app/**/generated/
.flutter-versions

# ---- Android ----
app/android/.gradle/
app/android/local.properties
app/android/key.properties
*.jks
*.keystore
app/android/app/release/

# ---- iOS / macOS ----
app/ios/Pods/
app/ios/.symlinks/
app/ios/Flutter/Flutter.framework
app/ios/Flutter/Flutter.podspec
**/*.iml

# ---- Editors / OS ----
.idea/
.vscode/
*.log
.DS_Store
Thumbs.db

# Test screenshots captured during development
_shots/

# Built artifacts (distribute via Play Store / GitHub Releases, not git)
*.apk
*.aab
installer/Output/

# Demo recordings — the GIF in webpage/ is committed; the raw recording + mp4 stay local
demo_vid.mkv
demo_2x.mp4

# Generated launcher icons are reproducible from tools/make_icon.py + flutter_launcher_icons
